# .env.example - Projeto Final (Aula 12). Copie para .env e preencha.

# --- Logs (verbosidade) ---
# DEBUG = maximo (sinais do probe, trechos, libs); INFO = decisoes; WARNING/ERROR = menos.
LOG_LEVEL=INFO

# --- LLM (Groq, OpenAI-compatible) ---
GROQ_API_KEY=coloque-sua-chave-groq
LLM_MODEL=llama-3.3-70b-versatile

# --- Embedding (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text

# --- OpenSearch ---
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=
OPENSEARCH_PASS=
OPENSEARCH_INDEX=projeto_final

# --- API (opcional): chaves aceitas no header X-API-Key, separadas por virgula ---
API_KEYS=

# --- Interface Gradio (interface.py) ---
API_URL=http://localhost:8000
GRADIO_PORT=7860
API_KEY=                      # use apenas se API_KEYS estiver configurado acima

# --- LangFuse (opcional) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3000
